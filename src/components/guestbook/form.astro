---
---
<form id="guestbook-form">
  <div class="input-row">
    <input type="text" name="name" placeholder="Nombre (Opcional)" />
    <input type="text" name="website" placeholder="Sitio web (opcional)" />
  </div>
  <textarea name="message" placeholder="Tu mensaje" required></textarea>
  <button type="submit">Enviar</button>
</form>

<script is:inline>
  const STORAGE_KEY = "guestbook_draft";
  const fields = ["name", "website", "message"];
  let form = null;

  document.addEventListener("DOMContentLoaded", () => {
    form = document.getElementById("guestbook-form");
    if (!form) return;

    const saved = sessionStorage.getItem(STORAGE_KEY);
    if (saved) {
      try {
        const data = JSON.parse(saved);
        for (const field of fields) {
          const el = form.querySelector(`[name="${field}"]`);
          if (el && data[field]) el.value = data[field];
        }
      } catch {}
    }
  });

  document.addEventListener("input", (e) => {
    if (!form) return;
    const target = e.target;
    if (!(target instanceof HTMLInputElement || target instanceof HTMLTextAreaElement)) return;
    if (!fields.includes(target.name)) return;
    const data = Object.fromEntries(new FormData(form).entries());
    sessionStorage.setItem(STORAGE_KEY, JSON.stringify(data));
  });

  document.addEventListener("submit", async (e) => {
    const target = e.target;
    if (!(target instanceof HTMLFormElement)) return;
    if (target.id !== "guestbook-form") return;
    e.preventDefault();

    const data = Object.fromEntries(new FormData(target).entries());

    const response = await fetch("/api/guestbook", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(data),
    });

    if (response.ok) {
      sessionStorage.removeItem(STORAGE_KEY);
      window.location.href = "/guestbook";
    } else {
      alert("Error enviando entrada");
    }
  });
</script>

<style>
  #guestbook-form * {
    box-sizing: border-box;
  }

  #guestbook-form {
    font-family: monospace;
    max-width: 100%;
    margin: 20px 0;
  }

  #guestbook-form input,
  #guestbook-form textarea {
    display: block;
    background-color: #282828;
    border: 1px solid #504945;
    color: #ebdbb2;
    padding: 4px 8px;
    margin-bottom: 8px;
    font-family: monospace;
    font-size: 14px;
    width: 100%; 
  }

  .input-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 8px;
  }

  .input-row input {
    flex: 1 1 200px;
    width: auto;
    margin-bottom: 0;
  }

  #guestbook-form textarea {
    width: 100%;
    height: 100px;
    resize: vertical;
    margin-bottom: 8px;
  }

  #guestbook-form input:focus,
  #guestbook-form textarea:focus {
    outline: none;
    border-color: #83a598;
  }

  #guestbook-form button {
    background-color: #282828;
    border: 1px solid #504945;
    color: #ebdbb2;
    padding: 4px 12px;
    font-family: monospace;
    cursor: pointer;
  }

  #guestbook-form button:hover {
    background-color: #3c3836;
  }

  #guestbook-form input::placeholder,
  #guestbook-form textarea::placeholder {
    color: #928374;
    opacity: 1;
  }

  #guestbook-form input::-moz-placeholder,
  #guestbook-form textarea::-moz-placeholder {
    color: #928374;
    opacity: 1;
  }

  #guestbook-form input::-webkit-input-placeholder,
  #guestbook-form textarea::-webkit-input-placeholder {
    color: #928374;
    opacity: 1;
  }
</style>
