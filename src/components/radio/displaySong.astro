---
export const prerender = false;
---

<p id="radioSong">Espera...</p>

<script>
const el = document.getElementById('radioSong');
const baseTitle = document.title;

const formatTitle = (raw = 'Nada') => {
  const [artist, ...song] = raw.split(' - ');

  return song.length
    ? `${song.join(' - ')} - ${artist}`
    : raw;
};

const events = new EventSource('/api/radio');

events.onmessage = (event) => {
  const formatted = formatTitle(event.data);

  el.textContent = `Sonando: ${formatted}`;
  document.title = `${formatted} | ${baseTitle}`;
};

events.onerror = () => {
  el.textContent = 'Radio desconectada';
  document.title = baseTitle;
};
</script>

<style>
  #radioSong {
    margin: 5px 0;
    font-weight: bold;
  }
</style>
